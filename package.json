{
  "name": "qasmoke",
  "version": "0.1.0",
  "description": "Tiny fixture-driven QA smoke tests for LLM and prompt regressions.",
  "type": "module",
  "bin": {
    "qasmoke": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "node --test",
    "smoke": "bash scripts/smoke.sh",
    "fixture:smoke": "node dist/cli.js run fixtures/basic --provider fixture --output .tmp/smoke-report.json",
    "prepare": "npm run build",
    "release:check": "npm run check && npm run build && npm test && npm run smoke && npm run package:smoke",
    "smoke:fixture": "node dist/cli.js run fixtures/basic --provider fixture --format summary",
    "smoke:failure": "node dist/cli.js run fixtures/failing --provider fixture --format summary",
    "package:smoke": "npm pack --dry-run"
  },
  "keywords": [
    "qa",
    "smoke-test",
    "llm",
    "regression",
    "regression-testing",
    "benchmark",
    "fixtures",
    "cli",
    "evals",
    "local-first"
  ],
  "license": "MIT",
  "author": "Roger Chappel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/qasmoke.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/qasmoke/issues"
  },
  "homepage": "https://github.com/rogerchappel/qasmoke#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.8.3"
  }
}
