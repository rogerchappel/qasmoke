{
  "name": "qasmoke",
  "workflow": [
    "inspect-fixture-pack",
    "run-deterministic-smoke",
    "review-json-report",
    "promote-or-fail-build"
  ],
  "commands": {
    "inspect": "qasmoke inspect fixtures/basic",
    "run": "qasmoke run fixtures/basic --provider fixture --output .tmp/report.json",
    "generate": "qasmoke generate fixtures/prompts.txt --name generated-smoke --out .tmp/generated",
    "summary": "qasmoke run fixtures/basic --provider fixture --format summary",
    "jsonl": "qasmoke run fixtures/basic --provider fixture --format jsonl"
  },
  "safety": {
    "network": false,
    "telemetry": false,
    "requiresSecrets": false
  },
  "outputs": [
    "json",
    "summary",
    "jsonl"
  ],
  "qualityGates": [
    "duplicate-case-id-validation",
    "matcher-validation",
    "negative-fixture-exit-code",
    "npm-pack-dry-run"
  ]
}
